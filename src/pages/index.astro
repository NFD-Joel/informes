---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import InformeCard from '../components/InformeCard.astro';
import { humanize } from '../lib/title';

const entries = await getCollection('informes');

// Sort newest first; entries without a date sink to the bottom.
entries.sort((a, b) => {
  const da = a.data.date?.getTime() ?? 0;
  const db = b.data.date?.getTime() ?? 0;
  return db - da;
});

const informes = entries.map((entry) => ({
  slug: entry.slug,
  title: entry.data.title ?? humanize(entry.slug),
  snippet: entry.body.replace(/\s+/g, ' ').trim().slice(0, 180) + '…',
}));
---

<Layout>
  <header class="topbar">
    <span class="logo">informes</span>
    <input
      class="search"
      type="search"
      placeholder="Buscar informe…"
      aria-label="Buscar informe"
      autocomplete="off"
    />
    <a class="home" href="https://xaytag.com" title="xaytag dashboard">↗ xaytag</a>
  </header>

  <main>
    <section class="grid">
      {informes.map((i) => <InformeCard slug={i.slug} title={i.title} snippet={i.snippet} />)}
    </section>

    <p class="empty" id="empty" hidden>Kein Informe gefunden.</p>

    <footer class="foot">
      <span id="count">{informes.length} informe{informes.length === 1 ? '' : 's'}</span>
      <span><span id="done">0</span> geschrieben</span>
    </footer>
  </main>
</Layout>

<script>
  import { getMarks, setMark } from '../lib/marks';
  import { promptPinOnLoad } from '../lib/pin';

  // Ask for the PIN up front so marking afterwards is frictionless.
  promptPinOnLoad();

  const cards = Array.from(document.querySelectorAll<HTMLElement>('.card'));
  const doneEl = document.getElementById('done');

  function refreshDone() {
    if (doneEl) {
      doneEl.textContent = String(
        cards.filter((c) => c.classList.contains('is-written')).length,
      );
    }
  }

  function applyMark(slug: string, written: boolean) {
    const card = cards.find((c) => c.dataset.slug === slug);
    const box = card?.querySelector<HTMLInputElement>('.mark');
    if (!card || !box) return;
    box.checked = written;
    card.classList.toggle('is-written', written);
  }

  // --- Load current state from the Worker ---
  getMarks().then((marks) => {
    for (const card of cards) {
      const slug = card.dataset.slug!;
      applyMark(slug, marks[slug] === true);
    }
    refreshDone();
  });

  // --- Toggle handler ---
  for (const card of cards) {
    const box = card.querySelector<HTMLInputElement>('.mark');
    box?.addEventListener('change', async () => {
      const slug = card.dataset.slug!;
      const want = box.checked;
      const ok = await setMark(slug, want);
      if (ok) {
        card.classList.toggle('is-written', want);
      } else {
        box.checked = !want; // revert on failure
      }
      refreshDone();
    });
  }

  // --- Search / filter ---
  const search = document.querySelector<HTMLInputElement>('.search');
  const count = document.getElementById('count');
  const empty = document.getElementById('empty');

  function filter() {
    const q = (search?.value ?? '').trim().toLowerCase();
    let visible = 0;
    for (const card of cards) {
      const match = card.textContent!.toLowerCase().includes(q);
      card.hidden = !match;
      if (match) visible++;
    }
    if (count) count.textContent = `${visible} informe${visible === 1 ? '' : 's'}`;
    if (empty) empty.hidden = visible !== 0;
  }
  search?.addEventListener('input', filter);
</script>

<style>
  .topbar {
    position: sticky;
    top: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.85rem clamp(1rem, 4vw, 2rem);
    background: rgba(13, 13, 16, 0.7);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
  }

  .logo {
    font-weight: 700;
    font-size: 1.15rem;
    letter-spacing: -0.02em;
    flex: none;
  }

  .search {
    flex: 1;
    min-width: 0;
    max-width: 420px;
    margin: 0 auto;
    padding: 0.5rem 0.9rem;
    font: inherit;
    font-size: 0.9rem;
    color: var(--text);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 999px;
    outline: none;
    transition: border-color 0.15s ease;
  }

  .search:focus {
    border-color: var(--border-hover);
  }

  .search::placeholder {
    color: var(--text-dim);
  }

  .home {
    flex: none;
    color: var(--text-dim);
    font-size: 0.85rem;
    transition: color 0.15s ease;
  }

  .home:hover {
    color: var(--text);
  }

  main {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: clamp(1.5rem, 4vw, 2.5rem) clamp(1rem, 4vw, 2rem) 3rem;
  }

  .empty {
    color: var(--text-dim);
    text-align: center;
    padding: 2rem 0;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }

  .foot {
    display: flex;
    justify-content: space-between;
    margin-top: 2.5rem;
    padding-top: 1.2rem;
    border-top: 1px solid var(--border);
    color: var(--text-dim);
    font-size: 0.8rem;
  }
</style>
